data/
*.db
*.db-shm
*.db-wal
*.backup
*.sqlite
*.sqlite3

# Log files
logs/
*.log

# User uploaded files
uploads/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

